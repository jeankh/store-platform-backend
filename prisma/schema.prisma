generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum StoreStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum CatalogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CouponStatus {
  ACTIVE
  INACTIVE
}

enum CouponType {
  FIXED
  PERCENTAGE
}

enum InventoryReservationStatus {
  ACTIVE
  RELEASED
}

enum StockMovementType {
  ADJUSTMENT
  RESERVATION
  RELEASE
}

enum CartStatus {
  ACTIVE
  ABANDONED
}

enum CheckoutStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  FULFILLED
}

model Tenant {
  id                 String              @id @default(uuid()) @db.Uuid
  slug               String              @unique
  name               String
  status             TenantStatus        @default(ACTIVE)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  settings           TenantSettings?
  stores             Store[]
  users              User[]
  customers          Customer[]
  products           Product[]
  categories         Category[]
  collections        Collection[]
  brands             Brand[]
  tags               Tag[]
  attributes         Attribute[]
  prices             Price[]
  compareAtPrices    CompareAtPrice[]
  scheduledPrices    ScheduledPrice[]
  coupons            Coupon[]
  promotionRules     PromotionRule[]
  promotionUsages    PromotionUsage[]
  warehouses         Warehouse[]
  inventoryLocations InventoryLocation[]
  stockItems         StockItem[]
  carts              Cart[]
  checkouts          Checkout[]
  orders             Order[]
  roles              Role[]
  auditLogs          AuditLog[]

  @@map("tenants")
}

model TenantSettings {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @unique @map("tenant_id") @db.Uuid
  defaultLocale   String   @map("default_locale")
  defaultCurrency String   @map("default_currency")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model Store {
  id                 String              @id @default(uuid()) @db.Uuid
  tenantId           String              @map("tenant_id") @db.Uuid
  slug               String
  name               String
  status             StoreStatus         @default(ACTIVE)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  settings           StoreSettings?
  locales            StoreLocale[]
  currencies         StoreCurrency[]
  taxConfig          StoreTaxConfig?
  products           Product[]
  categories         Category[]
  collections        Collection[]
  brands             Brand[]
  tags               Tag[]
  attributes         Attribute[]
  prices             Price[]
  compareAtPrices    CompareAtPrice[]
  scheduledPrices    ScheduledPrice[]
  coupons            Coupon[]
  promotionRules     PromotionRule[]
  promotionUsages    PromotionUsage[]
  warehouses         Warehouse[]
  inventoryLocations InventoryLocation[]
  stockItems         StockItem[]
  carts              Cart[]
  checkouts          Checkout[]
  orders             Order[]

  @@unique([tenantId, slug])
  @@map("stores")
}

model StoreSettings {
  id              String   @id @default(uuid()) @db.Uuid
  storeId         String   @unique @map("store_id") @db.Uuid
  defaultLocale   String   @map("default_locale")
  defaultCurrency String   @map("default_currency")
  displayName     String?  @map("display_name")
  supportEmail    String?  @map("support_email")
  supportPhone    String?  @map("support_phone")
  timezone        String?
  logoUrl         String?  @map("logo_url")
  primaryColor    String?  @map("primary_color")
  secondaryColor  String?  @map("secondary_color")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("store_settings")
}

model StoreLocale {
  id         String   @id @default(uuid()) @db.Uuid
  storeId    String   @map("store_id") @db.Uuid
  localeCode String   @map("locale_code")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, localeCode])
  @@map("store_locales")
}

model StoreCurrency {
  id           String   @id @default(uuid()) @db.Uuid
  storeId      String   @map("store_id") @db.Uuid
  currencyCode String   @map("currency_code")
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, currencyCode])
  @@map("store_currencies")
}

model StoreTaxConfig {
  id                     String   @id @default(uuid()) @db.Uuid
  storeId                String   @unique @map("store_id") @db.Uuid
  countryCode            String   @map("country_code")
  regionCode             String?  @map("region_code")
  taxInclusive           Boolean  @default(false) @map("tax_inclusive")
  taxProvider            String?  @map("tax_provider")
  taxCalculationStrategy String?  @map("tax_calculation_strategy")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  store                  Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("store_tax_configs")
}

model Customer {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  email           String
  passwordHash    String?             @map("password_hash")
  firstName       String              @map("first_name")
  lastName        String              @map("last_name")
  phone           String?
  status          CustomerStatus      @default(ACTIVE)
  isGuest         Boolean             @default(false) @map("is_guest")
  lastLoginAt     DateTime?           @map("last_login_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  addresses       CustomerAddress[]
  preferences     CustomerPreference?
  sessions        CustomerSession[]
  promotionUsages PromotionUsage[]
  carts           Cart[]
  checkouts       Checkout[]
  orders          Order[]

  @@unique([tenantId, email])
  @@map("customers")
}

model CustomerAddress {
  id                String   @id @default(uuid()) @db.Uuid
  customerId        String   @map("customer_id") @db.Uuid
  label             String?
  firstName         String   @map("first_name")
  lastName          String   @map("last_name")
  company           String?
  line1             String   @map("line_1")
  line2             String?  @map("line_2")
  city              String
  region            String?
  postalCode        String   @map("postal_code")
  countryCode       String   @map("country_code")
  phone             String?
  isDefaultShipping Boolean  @default(false) @map("is_default_shipping")
  isDefaultBilling  Boolean  @default(false) @map("is_default_billing")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_addresses")
}

model CustomerPreference {
  id                  String   @id @default(uuid()) @db.Uuid
  customerId          String   @unique @map("customer_id") @db.Uuid
  localeCode          String?  @map("locale_code")
  currencyCode        String?  @map("currency_code")
  marketingEmailOptIn Boolean  @default(false) @map("marketing_email_opt_in")
  marketingSmsOptIn   Boolean  @default(false) @map("marketing_sms_opt_in")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  customer            Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_preferences")
}

model CustomerSession {
  id               String    @id @default(uuid()) @db.Uuid
  customerId       String    @map("customer_id") @db.Uuid
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  refreshTokenHash String    @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_sessions")
}

model Cart {
  id         String     @id @default(uuid()) @db.Uuid
  tenantId   String     @map("tenant_id") @db.Uuid
  storeId    String     @map("store_id") @db.Uuid
  customerId String?    @map("customer_id") @db.Uuid
  guestToken String?    @map("guest_token")
  status     CartStatus @default(ACTIVE)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  store      Store      @relation(fields: [storeId], references: [id])
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items      CartItem[]
  totals     CartTotal?
  checkouts  Checkout[]

  @@index([guestToken])
  @@map("carts")
}

model CartItem {
  id                 String         @id @default(uuid()) @db.Uuid
  cartId             String         @map("cart_id") @db.Uuid
  variantId          String         @map("variant_id") @db.Uuid
  quantity           Int
  unitAmountSnapshot Int            @map("unit_amount_snapshot")
  currencyCode       String         @map("currency_code")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  cart               Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant            ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model CartTotal {
  id             String   @id @default(uuid()) @db.Uuid
  cartId         String   @unique @map("cart_id") @db.Uuid
  subtotalAmount Int      @map("subtotal_amount")
  discountAmount Int      @map("discount_amount")
  taxAmount      Int      @map("tax_amount")
  totalAmount    Int      @map("total_amount")
  currencyCode   String   @map("currency_code")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  cart           Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@map("cart_totals")
}

model Checkout {
  id              String                   @id @default(uuid()) @db.Uuid
  tenantId        String                   @map("tenant_id") @db.Uuid
  storeId         String                   @map("store_id") @db.Uuid
  cartId          String                   @map("cart_id") @db.Uuid
  customerId      String?                  @map("customer_id") @db.Uuid
  status          CheckoutStatus           @default(ACTIVE)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  tenant          Tenant                   @relation(fields: [tenantId], references: [id])
  store           Store                    @relation(fields: [storeId], references: [id])
  cart            Cart                     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  customer        Customer?                @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items           CheckoutItem[]
  addresses       CheckoutAddress[]
  shippingMethods CheckoutShippingMethod[]
  discounts       CheckoutDiscount[]
  taxes           CheckoutTax[]
  orders          Order[]

  @@map("checkouts")
}

model CheckoutItem {
  id                 String         @id @default(uuid()) @db.Uuid
  checkoutId         String         @map("checkout_id") @db.Uuid
  variantId          String         @map("variant_id") @db.Uuid
  quantity           Int
  unitAmountSnapshot Int            @map("unit_amount_snapshot")
  currencyCode       String         @map("currency_code")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  checkout           Checkout       @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  variant            ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("checkout_items")
}

model CheckoutAddress {
  id          String   @id @default(uuid()) @db.Uuid
  checkoutId  String   @map("checkout_id") @db.Uuid
  type        String
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  line1       String   @map("line_1")
  line2       String?  @map("line_2")
  city        String
  region      String?
  postalCode  String   @map("postal_code")
  countryCode String   @map("country_code")
  phone       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  checkout    Checkout @relation(fields: [checkoutId], references: [id], onDelete: Cascade)

  @@map("checkout_addresses")
}

model CheckoutShippingMethod {
  id           String   @id @default(uuid()) @db.Uuid
  checkoutId   String   @map("checkout_id") @db.Uuid
  methodCode   String   @map("method_code")
  methodLabel  String   @map("method_label")
  amount       Int
  currencyCode String   @map("currency_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  checkout     Checkout @relation(fields: [checkoutId], references: [id], onDelete: Cascade)

  @@map("checkout_shipping_methods")
}

model CheckoutDiscount {
  id           String   @id @default(uuid()) @db.Uuid
  checkoutId   String   @map("checkout_id") @db.Uuid
  code         String?
  amount       Int
  currencyCode String   @map("currency_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  checkout     Checkout @relation(fields: [checkoutId], references: [id], onDelete: Cascade)

  @@map("checkout_discounts")
}

model CheckoutTax {
  id           String   @id @default(uuid()) @db.Uuid
  checkoutId   String   @map("checkout_id") @db.Uuid
  name         String
  amount       Int
  currencyCode String   @map("currency_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  checkout     Checkout @relation(fields: [checkoutId], references: [id], onDelete: Cascade)

  @@map("checkout_taxes")
}

model Order {
  id             String               @id @default(uuid()) @db.Uuid
  tenantId       String               @map("tenant_id") @db.Uuid
  storeId        String               @map("store_id") @db.Uuid
  checkoutId     String               @map("checkout_id") @db.Uuid
  customerId     String?              @map("customer_id") @db.Uuid
  status         OrderStatus          @default(PENDING)
  currencyCode   String               @map("currency_code")
  subtotalAmount Int                  @map("subtotal_amount")
  discountAmount Int                  @map("discount_amount")
  taxAmount      Int                  @map("tax_amount")
  totalAmount    Int                  @map("total_amount")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  store          Store                @relation(fields: [storeId], references: [id])
  checkout       Checkout             @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  customer       Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  addresses      OrderAddress[]
  statusHistory  OrderStatusHistory[]
  notes          OrderNote[]

  @@map("orders")
}

model OrderItem {
  id                 String         @id @default(uuid()) @db.Uuid
  orderId            String         @map("order_id") @db.Uuid
  variantId          String         @map("variant_id") @db.Uuid
  quantity           Int
  unitAmountSnapshot Int            @map("unit_amount_snapshot")
  currencyCode       String         @map("currency_code")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  order              Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant            ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model OrderAddress {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  type        String
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  line1       String   @map("line_1")
  line2       String?  @map("line_2")
  city        String
  region      String?
  postalCode  String   @map("postal_code")
  countryCode String   @map("country_code")
  phone       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_addresses")
}

model OrderStatusHistory {
  id          String       @id @default(uuid()) @db.Uuid
  orderId     String       @map("order_id") @db.Uuid
  fromStatus  OrderStatus? @map("from_status")
  toStatus    OrderStatus  @map("to_status")
  actorUserId String?      @map("actor_user_id") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actorUser   User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@map("order_status_history")
}

model OrderNote {
  id           String   @id @default(uuid()) @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  content      String
  createdAt    DateTime @default(now()) @map("created_at")
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  authorUser   User     @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@map("order_notes")
}

model Product {
  id          String              @id @default(uuid()) @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  storeId     String              @map("store_id") @db.Uuid
  slug        String
  title       String
  description String?
  status      CatalogStatus       @default(DRAFT)
  brandId     String?             @map("brand_id") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  store       Store               @relation(fields: [storeId], references: [id])
  brand       Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  variants    ProductVariant[]
  categories  ProductCategory[]
  collections ProductCollection[]
  tags        ProductTag[]
  media       ProductMedia[]

  @@unique([storeId, slug])
  @@map("products")
}

model ProductVariant {
  id              String                  @id @default(uuid()) @db.Uuid
  productId       String                  @map("product_id") @db.Uuid
  sku             String
  title           String
  status          CatalogStatus           @default(DRAFT)
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  product         Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributes      VariantAttributeValue[]
  prices          Price[]
  compareAtPrices CompareAtPrice[]
  scheduledPrices ScheduledPrice[]
  stockItems      StockItem[]
  cartItems       CartItem[]
  checkoutItems   CheckoutItem[]
  orderItems      OrderItem[]

  @@unique([productId, sku])
  @@map("product_variants")
}

model Category {
  id        String            @id @default(uuid()) @db.Uuid
  tenantId  String            @map("tenant_id") @db.Uuid
  storeId   String            @map("store_id") @db.Uuid
  slug      String
  name      String
  parentId  String?           @map("parent_id") @db.Uuid
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  store     Store             @relation(fields: [storeId], references: [id])
  parent    Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[]        @relation("CategoryTree")
  products  ProductCategory[]

  @@unique([storeId, slug])
  @@map("categories")
}

model ProductCategory {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@map("product_categories")
}

model Collection {
  id        String              @id @default(uuid()) @db.Uuid
  tenantId  String              @map("tenant_id") @db.Uuid
  storeId   String              @map("store_id") @db.Uuid
  slug      String
  name      String
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  store     Store               @relation(fields: [storeId], references: [id])
  products  ProductCollection[]

  @@unique([storeId, slug])
  @@map("collections")
}

model ProductCollection {
  id           String     @id @default(uuid()) @db.Uuid
  productId    String     @map("product_id") @db.Uuid
  collectionId String     @map("collection_id") @db.Uuid
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([productId, collectionId])
  @@map("product_collections")
}

model Brand {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  storeId   String    @map("store_id") @db.Uuid
  slug      String
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  store     Store     @relation(fields: [storeId], references: [id])
  products  Product[]

  @@unique([storeId, slug])
  @@map("brands")
}

model Tag {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @map("tenant_id") @db.Uuid
  storeId   String       @map("store_id") @db.Uuid
  value     String
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  store     Store        @relation(fields: [storeId], references: [id])
  products  ProductTag[]

  @@unique([storeId, value])
  @@map("tags")
}

model ProductTag {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  tagId     String  @map("tag_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@map("product_tags")
}

model Attribute {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  storeId   String           @map("store_id") @db.Uuid
  name      String
  code      String
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  store     Store            @relation(fields: [storeId], references: [id])
  values    AttributeValue[]

  @@unique([storeId, code])
  @@map("attributes")
}

model AttributeValue {
  id          String                  @id @default(uuid()) @db.Uuid
  attributeId String                  @map("attribute_id") @db.Uuid
  value       String
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  attribute   Attribute               @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variants    VariantAttributeValue[]

  @@unique([attributeId, value])
  @@map("attribute_values")
}

model VariantAttributeValue {
  id               String         @id @default(uuid()) @db.Uuid
  variantId        String         @map("variant_id") @db.Uuid
  attributeValueId String         @map("attribute_value_id") @db.Uuid
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeValueId])
  @@map("variant_attribute_values")
}

model ProductMedia {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  url       String
  altText   String?  @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_media")
}

model Price {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  storeId      String         @map("store_id") @db.Uuid
  variantId    String         @map("variant_id") @db.Uuid
  currencyCode String         @map("currency_code")
  amount       Int
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  store        Store          @relation(fields: [storeId], references: [id])
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, currencyCode])
  @@map("prices")
}

model CompareAtPrice {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  storeId      String         @map("store_id") @db.Uuid
  variantId    String         @map("variant_id") @db.Uuid
  currencyCode String         @map("currency_code")
  amount       Int
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  store        Store          @relation(fields: [storeId], references: [id])
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, currencyCode])
  @@map("compare_at_prices")
}

model ScheduledPrice {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  storeId      String         @map("store_id") @db.Uuid
  variantId    String         @map("variant_id") @db.Uuid
  currencyCode String         @map("currency_code")
  amount       Int
  startsAt     DateTime       @map("starts_at")
  endsAt       DateTime?      @map("ends_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  store        Store          @relation(fields: [storeId], references: [id])
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("scheduled_prices")
}

model Coupon {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String           @map("tenant_id") @db.Uuid
  storeId    String           @map("store_id") @db.Uuid
  code       String
  type       CouponType
  value      Int
  status     CouponStatus     @default(ACTIVE)
  startsAt   DateTime?        @map("starts_at")
  endsAt     DateTime?        @map("ends_at")
  usageLimit Int?             @map("usage_limit")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  store      Store            @relation(fields: [storeId], references: [id])
  rules      PromotionRule[]
  usages     PromotionUsage[]

  @@unique([storeId, code])
  @@map("coupons")
}

model PromotionRule {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  couponId  String?  @map("coupon_id") @db.Uuid
  resource  String
  operator  String
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  store     Store    @relation(fields: [storeId], references: [id])
  coupon    Coupon?  @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@map("promotion_rules")
}

model PromotionUsage {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  storeId    String    @map("store_id") @db.Uuid
  couponId   String    @map("coupon_id") @db.Uuid
  customerId String?   @map("customer_id") @db.Uuid
  orderId    String?   @map("order_id")
  usedAt     DateTime  @default(now()) @map("used_at")
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  store      Store     @relation(fields: [storeId], references: [id])
  coupon     Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@map("promotion_usages")
}

model Warehouse {
  id        String              @id @default(uuid()) @db.Uuid
  tenantId  String              @map("tenant_id") @db.Uuid
  storeId   String              @map("store_id") @db.Uuid
  slug      String
  name      String
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  store     Store               @relation(fields: [storeId], references: [id])
  locations InventoryLocation[]

  @@unique([storeId, slug])
  @@map("warehouses")
}

model InventoryLocation {
  id           String                 @id @default(uuid()) @db.Uuid
  tenantId     String                 @map("tenant_id") @db.Uuid
  storeId      String                 @map("store_id") @db.Uuid
  warehouseId  String                 @map("warehouse_id") @db.Uuid
  slug         String
  name         String
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  store        Store                  @relation(fields: [storeId], references: [id])
  warehouse    Warehouse              @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  levels       InventoryLevel[]
  reservations InventoryReservation[]
  adjustments  StockAdjustment[]
  movements    StockMovement[]
  alerts       LowStockAlert[]

  @@unique([warehouseId, slug])
  @@map("inventory_locations")
}

model StockItem {
  id           String                 @id @default(uuid()) @db.Uuid
  tenantId     String                 @map("tenant_id") @db.Uuid
  storeId      String                 @map("store_id") @db.Uuid
  variantId    String                 @map("variant_id") @db.Uuid
  skuSnapshot  String                 @map("sku_snapshot")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  store        Store                  @relation(fields: [storeId], references: [id])
  variant      ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Cascade)
  levels       InventoryLevel[]
  reservations InventoryReservation[]
  adjustments  StockAdjustment[]
  movements    StockMovement[]
  alerts       LowStockAlert[]

  @@unique([variantId])
  @@map("stock_items")
}

model InventoryLevel {
  id                String            @id @default(uuid()) @db.Uuid
  stockItemId       String            @map("stock_item_id") @db.Uuid
  locationId        String            @map("location_id") @db.Uuid
  availableQuantity Int               @default(0) @map("available_quantity")
  reservedQuantity  Int               @default(0) @map("reserved_quantity")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  stockItem         StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  location          InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([stockItemId, locationId])
  @@map("inventory_levels")
}

model InventoryReservation {
  id            String                     @id @default(uuid()) @db.Uuid
  stockItemId   String                     @map("stock_item_id") @db.Uuid
  locationId    String                     @map("location_id") @db.Uuid
  referenceType String                     @map("reference_type")
  referenceId   String                     @map("reference_id")
  quantity      Int
  status        InventoryReservationStatus @default(ACTIVE)
  createdAt     DateTime                   @default(now()) @map("created_at")
  updatedAt     DateTime                   @updatedAt @map("updated_at")
  stockItem     StockItem                  @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  location      InventoryLocation          @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("inventory_reservations")
}

model StockAdjustment {
  id          String            @id @default(uuid()) @db.Uuid
  stockItemId String            @map("stock_item_id") @db.Uuid
  locationId  String            @map("location_id") @db.Uuid
  delta       Int
  reason      String
  actorUserId String?           @map("actor_user_id") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at")
  stockItem   StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  location    InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  actorUser   User?             @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@map("stock_adjustments")
}

model StockMovement {
  id            String            @id @default(uuid()) @db.Uuid
  stockItemId   String            @map("stock_item_id") @db.Uuid
  locationId    String            @map("location_id") @db.Uuid
  movementType  StockMovementType @map("movement_type")
  delta         Int
  referenceType String?           @map("reference_type")
  referenceId   String?           @map("reference_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  stockItem     StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  location      InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

model LowStockAlert {
  id          String            @id @default(uuid()) @db.Uuid
  stockItemId String            @map("stock_item_id") @db.Uuid
  locationId  String            @map("location_id") @db.Uuid
  threshold   Int
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  stockItem   StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  location    InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("low_stock_alerts")
}

model User {
  id                   String               @id @default(uuid()) @db.Uuid
  tenantId             String               @map("tenant_id") @db.Uuid
  email                String
  passwordHash         String               @map("password_hash")
  status               UserStatus           @default(ACTIVE)
  lastLoginAt          DateTime?            @map("last_login_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  tenant               Tenant               @relation(fields: [tenantId], references: [id])
  staffProfile         StaffProfile?
  authSessions         AuthSession[]
  refreshTokens        RefreshToken[]
  userRoles            UserRole[]
  auditLogs            AuditLog[]           @relation("AuditActor")
  stockAdjustments     StockAdjustment[]
  orderStatusHistories OrderStatusHistory[]
  orderNotes           OrderNote[]

  @@unique([tenantId, email])
  @@map("users")
}

model StaffProfile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_profiles")
}

model AuthSession {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  ipAddress     String?        @map("ip_address")
  userAgent     String?        @map("user_agent")
  expiresAt     DateTime       @map("expires_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@map("auth_sessions")
}

model RefreshToken {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  tokenHash String      @map("token_hash")
  expiresAt DateTime    @map("expires_at")
  revokedAt DateTime?   @map("revoked_at")
  createdAt DateTime    @default(now()) @map("created_at")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   AuthSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@map("refresh_tokens")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  name            String
  code            String
  isSystem        Boolean          @default(false) @map("is_system")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, code])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique
  name            String
  resource        String
  action          String
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
