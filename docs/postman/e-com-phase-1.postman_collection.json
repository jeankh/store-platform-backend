  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Bootstrap Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.user && body.user.tenantId) pm.collectionVariables.set('tenantId', body.user.tenantId);",
                  "if (body.user && body.user.id) pm.collectionVariables.set('userId', body.user.id);",
                  "if (body.accessToken) pm.collectionVariables.set('accessToken', body.accessToken);",
                  "if (body.refreshToken) pm.collectionVariables.set('refreshToken', body.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"email\": \"owner@acme.com\",\n  \"password\": \"super-secret-password\",\n  \"firstName\": \"Acme\",\n  \"lastName\": \"Owner\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/auth/bootstrap",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "auth", "bootstrap"]
            }
          }
        },
        {
          "name": "Login",
